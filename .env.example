# ═══════════════════════════════════════════════════════════════════════════
# platform-docker — Variables de entorno para despliegue en VPS del cliente
#
# Copialo a .env y editá los valores reales:
#   cp .env.example .env
#
# Después:
#   ./install.sh          → primera instalación
#   ./update.sh           → cuando cambies IMAGE_*_TAG para actualizar versión
#
# Leyenda: [REQ] = requerido, [OPT] = opcional (dejá vacío para desactivar)
# ═══════════════════════════════════════════════════════════════════════════

# ─── Versiones de imágenes (Docker Hub) ─────────────────────────────────────
# Editá estas dos líneas y corrés ./update.sh para cambiar de versión.
IMAGE_BACKEND_TAG=javierrodriguez4/platform-backend:0.3.1
IMAGE_FRONTEND_TAG=javierrodriguez4/platform-frontend:0.6.0

# ─── Core ────────────────────────────────────────────────────────────────────

# [OPT] Modo de ejecución — normalmente no se toca en producción
NODE_ENV=production

# [REQ] Postgres externo — el template no crea su propia DB.
# Formatos: postgresql://user:pass@host:5432/platform?schema=public
DATABASE_URL=postgresql://platform_user:CAMBIAR@postgres:5432/platform?schema=public

# [OPT] true SOLO en el primer arranque sobre DB vacía (Prisma crea tablas).
#       Dejalo en false después para no romper DBs compartidas.
RUN_DB_PUSH=false

# [REQ] Secret para firmar JWTs — generá con: openssl rand -hex 32
JWT_SECRET=CAMBIAR_USAR_openssl_rand_hex_32
# [OPT] Duración del token (default: 7d)
JWT_EXPIRES_IN=7d

# [REQ] Dominio público (sin https://). Necesario para CORS y Traefik.
PUBLIC_HOST=platform.cliente.com
# [REQ] Origen CORS — debe coincidir con el dominio público
CORS_ORIGIN=https://platform.cliente.com
# [OPT] URL pública de la instancia (la usa el aviso de reagendado y la URL corta
#        /c/{token} "agregar a mi calendario"). En Swarm (stack.yml) se deriva de
#        PUBLIC_HOST; en docker-compose seteala acá. Vacío → esas features inertes.
PLATFORM_PUBLIC_URL=https://platform.cliente.com
# [OPT] Puerto local del frontend (solo docker-compose.yml; Swarm usa Traefik)
FRONTEND_PORT=8080
# [OPT] Red overlay externa del cliente (solo stack.yml / Swarm)
EXTERNAL_NETWORK=ClienteNet

# ─── Seed admin ──────────────────────────────────────────────────────────────
# Crea el usuario admin inicial al levantar. Idempotente: no hace nada si ya existe.
# [REQ]
SEED_ADMIN_EMAIL=admin@cliente.com
# [REQ]
SEED_ADMIN_PASSWORD=CAMBIAR_ESTO_AL_INSTALAR
# [OPT]
SEED_ADMIN_NAME=Administrador

# ─── Auth ────────────────────────────────────────────────────────────────────

# [OPT] Habilita login local + federación Chatwoot. false → solo OIDC/Keycloak.
AUTH_LOCAL_ENABLED=true
# [OPT] Clave de servicio para el endpoint /api/bot. Vacío → responde 503.
BOT_SERVICE_KEY=

# ─── OIDC / Keycloak ─────────────────────────────────────────────────────────
# Para habilitar "Entrar con Keycloak" setear OIDC_ENABLED=true y completar
# issuer, client_id, client_secret y redirect_uri. El resto tiene defaults.
# Default OFF → login local sigue intacto (ej. Botulinic).

# [OPT] Habilitar SSO con Keycloak
OIDC_ENABLED=false
# [OPT] Issuer público — URL del realm en Keycloak (usado por el browser y para validar iss)
#        Ej: https://keycloak.cliente.com/realms/production
OIDC_ISSUER=
# [OPT] Issuer interno para llamadas server-side si Keycloak está en la misma red docker.
#        Si vacío, se usa OIDC_ISSUER.
OIDC_INTERNAL_ISSUER=
# [OPT] Client ID del realm en Keycloak
OIDC_CLIENT_ID=
# [OPT] Client secret del realm en Keycloak
OIDC_CLIENT_SECRET=
# [OPT] Callback del backend. Ej: https://platform.cliente.com/api/auth/oidc/callback
OIDC_REDIRECT_URI=
# [OPT] Ruta del frontend a la que redirige el callback tras emitir el JWT propio
OIDC_POST_LOGIN_REDIRECT=/oidc/callback
# [OPT] URL post-logout que Keycloak redirige tras end_session.
#        Debe estar registrada en "Valid post logout redirect URIs" del client.
#        Si vacío, se deriva del origin de OIDC_REDIRECT_URI + '/login'.
OIDC_POST_LOGOUT_REDIRECT=
# [OPT] Role de Keycloak (realm_access.roles) que mapea al rol admin de Platform
OIDC_ROLE_ADMIN=platform-admin
# [OPT] Rol Platform por default si el user de Keycloak no trae el role admin
OIDC_DEFAULT_ROLE_CODE=user

# ─── Keycloak Admin API ───────────────────────────────────────────────────────
# Habilita el ABM de usuarios de Keycloak desde Platform (/api/admin/keycloak).
# Requiere un service account con rol 'manage-users' en el realm.
# [OPT]
KEYCLOAK_ADMIN_CLIENT_ID=
# [OPT]
KEYCLOAK_ADMIN_CLIENT_SECRET=

# ─── Chatwoot ────────────────────────────────────────────────────────────────
# SSO + creación automática de agentes desde Platform.
# Vacío en todas → integración desactivada.

# [OPT] URL pública de Chatwoot (para embeber en iframe)
CHATWOOT_PUBLIC_URL=
# [OPT] URL interna de Chatwoot (para llamadas server-side; suele ser el container/host)
CHATWOOT_INTERNAL_URL=
# [OPT] Platform Token (Chatwoot admin → Settings → Integrations → Platform Apps)
CHATWOOT_PLATFORM_TOKEN=
# [OPT] Account ID de Chatwoot (default: 1)
CHATWOOT_ACCOUNT_ID=1
# [OPT] Access token de un user admin de Chatwoot (Profile → Access Token).
#        Necesario para asignar users a inboxes automáticamente.
CHATWOOT_ADMIN_USER_TOKEN=
# [OPT] Inboxes a los que se asigna cada user nuevo. Formato CSV: "1" o "1,2,3". Vacío = no asignar.
CHATWOOT_DEFAULT_INBOX_IDS=
# [OPT] Rol Chatwoot asignado al admin de Platform
CHATWOOT_ROLE_FOR_PLATFORM_ADMIN=administrator
# [OPT] Rol Chatwoot asignado al usuario estándar de Platform
CHATWOOT_ROLE_FOR_PLATFORM_USER=agent

# ─── Evolution API (WhatsApp) ────────────────────────────────────────────────
# Gateway de WhatsApp. La config se siembra en `settings` al levantar el
# container para que el stack arranque con WhatsApp ya configurado.
# Vacío en todas → módulo desactivado.

# [OPT] URL base de la Evolution API (ej: http://evolution:8080)
EVOLUTION_BASE_URL=
# [OPT] Nombre de la instancia de WhatsApp
EVOLUTION_INSTANCE_NAME=
# [OPT] Token de la instancia
EVOLUTION_INSTANCE_TOKEN=

# ─── Metabase ────────────────────────────────────────────────────────────────
# Embedded analytics con JWT signed embedding.
# Requiere METABASE_SITE_URL + METABASE_EMBED_SECRET para activar.

# [OPT] URL pública de Metabase (ej: https://metabase.cliente.com)
METABASE_SITE_URL=
# [OPT] Embed secret (Metabase admin → Settings → Embedding → Embedding Secret Key)
METABASE_EMBED_SECRET=
# [OPT] ID del dashboard por defecto a embeber
METABASE_DEFAULT_DASHBOARD_ID=

# ─── n8n ─────────────────────────────────────────────────────────────────────
# Automatizaciones embebidas en iframe.
# En n8n setear N8N_SECURITY_HEADERS_FRAME_ANCESTORS al PUBLIC_HOST.

# [OPT] URL pública de n8n (para embeber en iframe)
N8N_PUBLIC_URL=
# [OPT] URL interna de n8n (para llamadas API server-side)
N8N_INTERNAL_URL=
# [OPT] API key de n8n
N8N_API_KEY=

# ─── NocoDB ──────────────────────────────────────────────────────────────────
# Shared views via iframe.

# [OPT] URL pública de NocoDB
NOCODB_PUBLIC_URL=

# ─── Object Storage (MinIO / S3) ─────────────────────────────────────────────
# Almacenamiento de archivos: logo de marca (branding) y documentos de pacientes.
# Si S3_ENDPOINT está vacío, los uploads responden 503 ("almacenamiento no
# configurado"). Para activarlos, completá endpoint + credenciales + bucket.

# [OPT] Endpoint del object storage (ej: https://s3.cliente.com — MinIO o S3)
S3_ENDPOINT=
# [OPT] URL pública desde donde se sirven los objetos (ej: https://s3.cliente.com).
#        Si vacío, se usa S3_ENDPOINT.
S3_PUBLIC_URL=
# [OPT] Región (default: us-east-1; MinIO la ignora pero el SDK la pide)
S3_REGION=us-east-1
# [OPT] Access key del object storage
S3_ACCESS_KEY=
# [OPT] Secret key del object storage
S3_SECRET_KEY=
# [OPT] Bucket donde viven los assets (default: platform-assets). Debe existir y
#        ser de lectura pública para servir logos/documentos por URL.
S3_BUCKET=platform-assets
