# ═══════════════════════════════════════════════════════════════════════════
# platform-docker — Variables de entorno para despliegue en VPS del cliente
#
# Copialo a .env y editá los valores reales:
#   cp .env.example .env
#
# Después:
#   ./install.sh          → primera instalación
#   ./update.sh           → cuando cambies IMAGE_*_TAG para actualizar versión
# ═══════════════════════════════════════════════════════════════════════════

# ─── Versiones de imágenes (Docker Hub) ────────────────────────────────────
# Acá ponés las versiones que quieras correr. Para subir/bajar versión,
# editás estas dos líneas y corrés ./update.sh
IMAGE_BACKEND_TAG=javierrodriguez4/platform-backend:0.3.1
IMAGE_FRONTEND_TAG=javierrodriguez4/platform-frontend:0.6.0

# ─── Modo ──────────────────────────────────────────────────────────────────
NODE_ENV=production

# ─── Postgres EXTERNO (el template no crea su propia DB) ───────────────────
# Apuntá a una DB ya existente. Formatos comunes:
#   postgresql://user:pass@host_externo:5432/platform?schema=public
#   postgresql://user:pass@host.docker.internal:5432/platform?schema=public   (host machine)
#   postgresql://user:pass@nombre_container:5432/platform?schema=public       (otra red docker)
DATABASE_URL=postgresql://platform_user:CAMBIAR@postgres:5432/platform?schema=public

# Primer arranque sobre DB vacía → poné true SOLO la primera vez para que Prisma
# cree las tablas. Después poné false (en DB compartida `db push` puede dropear
# tablas que no estén en el schema).
RUN_DB_PUSH=false

# ─── Auth ──────────────────────────────────────────────────────────────────
# Generar con: openssl rand -hex 32
JWT_SECRET=CAMBIAR_USAR_openssl_rand_hex_32
JWT_EXPIRES_IN=7d

# ─── Red y dominio ─────────────────────────────────────────────────────────
# Dominio público (sin https://). Sólo necesario en stack.yml (Traefik).
PUBLIC_HOST=platform.cliente.com

# Origen permitido por CORS — debe coincidir con el dominio público.
CORS_ORIGIN=https://platform.cliente.com

# Puerto local del frontend (solo docker-compose.yml; en Swarm va detrás de Traefik).
FRONTEND_PORT=8080

# Red overlay externa del cliente — donde viven postgres / chatwoot / traefik.
# Sólo se usa en stack.yml (Swarm). Ej: BrainNet, BotulinicNet, etc.
EXTERNAL_NETWORK=ClienteNet

# ─── Branding ──────────────────────────────────────────────────────────────
APP_NAME=Cliente Platform
APP_LOGO_URL=https://cliente.com/logo.png
APP_PRIMARY_COLOR=#3b82f6

# ─── Seed admin (idempotente — sólo crea si no existe) ─────────────────────
SEED_ADMIN_EMAIL=admin@cliente.com
SEED_ADMIN_PASSWORD=CAMBIAR_ESTO_AL_INSTALAR
SEED_ADMIN_NAME=Administrador

# ─── Integraciones (todas opcionales — dejá vacío para desactivar el módulo) ─

# Metabase (JWT signed embedding)
METABASE_SITE_URL=
METABASE_EMBED_SECRET=
METABASE_DEFAULT_DASHBOARD_ID=

# Chatwoot (SSO via Platform API)
# CHATWOOT_INTERNAL_URL apunta al container/host interno; PUBLIC_URL al dominio público.
CHATWOOT_PUBLIC_URL=
CHATWOOT_INTERNAL_URL=
CHATWOOT_PLATFORM_TOKEN=

# NocoDB (shared views via API)
NOCODB_PUBLIC_URL=
NOCODB_API_TOKEN=

# n8n (iframe — en n8n hay que setear N8N_SECURITY_HEADERS_FRAME_ANCESTORS al PUBLIC_HOST)
N8N_PUBLIC_URL=
